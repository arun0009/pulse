{
  "title": "Pulse — Service Overview",
  "uid": "pulse-overview",
  "tags": ["pulse", "slo", "spring-boot"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(http_server_requests_seconds_count, application)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false,
        "refresh": 2
      },
      {
        "name": "env",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(http_server_requests_seconds_count{application=~\"$service\"}, env)",
        "includeAll": true,
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Availability (5m)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "1 - (sum(rate(http_server_requests_seconds_count{application=~\"$service\",env=~\"$env\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=~\"$service\",env=~\"$env\"}[5m])))"
      }]
    },
    {
      "type": "stat",
      "title": "p99 latency (5m)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\",env=~\"$env\"}[5m])) by (le))"
      }]
    },
    {
      "type": "stat",
      "title": "RPS",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\",env=~\"$env\"}[5m]))"
      }]
    },
    {
      "type": "stat",
      "title": "Cardinality firewall — overflows",
      "description": "Rate of values rewritten by the cardinality firewall in the last 5m. Anything >0 means a runaway tag was detected and capped.",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(rate(pulse_cardinality_overflow_total{application=~\"$service\",env=~\"$env\"}[5m]))"
      }]
    },
    {
      "type": "timeseries",
      "title": "RED — Rate / Errors / Duration",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\",env=~\"$env\"}[1m])) by (status)",
          "legendFormat": "rps {{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency percentiles",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\",env=~\"$env\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\",env=~\"$env\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\",env=~\"$env\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Wide events (pulse.events)",
      "description": "Bounded-cardinality counter. One series per business event name, regardless of attributes.",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "sum by (event) (rate(pulse_events_total{application=~\"$service\",env=~\"$env\"}[5m]))",
        "legendFormat": "{{event}}"
      }]
    },
    {
      "type": "timeseries",
      "title": "Timeout-budget exhaustion",
      "description": "Rate of requests that hit a downstream with <minimum-budget remaining. High values indicate a deeply nested / slow dependency.",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [{
        "expr": "sum by (application) (rate(pulse_timeout_budget_exhausted_total{application=~\"$service\",env=~\"$env\"}[5m]))"
      }]
    }
  ]
}
